generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ExerciseType {
  endurance
  strength
  balance
  flexibility
}

enum MediaType {
  image
  video
}

model Exercise {
  id          Int    @id @default(autoincrement())
  slug        String @unique
  title       String
  description String

  type ExerciseType? @default(strength)

  media     ExerciseMedia[]
  equipment ExerciseEquipment[]
  muscles   ExerciseMuscle[]
  routines  RoutineExercise[]
  workouts  WorkoutExercise[]

  metadata Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
}

model ExerciseMedia {
  id         Int       @id @default(autoincrement())
  exerciseId Int
  type       MediaType
  path       String
  order      Int?
  createdAt  DateTime  @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model Equipment {
  id   Int     @id @default(autoincrement())
  icon String?

  translations EquipmentTranslation[]
  exercises    ExerciseEquipment[]
}

model EquipmentTranslation {
  id          Int    @id @default(autoincrement())
  equipmentId Int
  lang        String
  name        String

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([equipmentId, lang])
}

model ExerciseEquipment {
  exerciseId  Int
  equipmentId Int

  exercise  Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@id([exerciseId, equipmentId])
}

model Muscle {
  id          Int    @id @default(autoincrement())
  description String

  translations MuscleTranslation[]

  exercises ExerciseMuscle[]
  groups    MuscleToGroup[]
  workouts  WorkoutMuscle[]
}

model MuscleTranslation {
  id       Int    @id @default(autoincrement())
  muscleId Int
  lang     String
  name     String

  muscle Muscle @relation(fields: [muscleId], references: [id], onDelete: Cascade)

  @@unique([muscleId, lang])
}

model MuscleGroup {
  id          Int    @id @default(autoincrement())
  description String

  translations MuscleGroupTranslation[]
  muscles      MuscleToGroup[]
}

model MuscleGroupTranslation {
  id      Int    @id @default(autoincrement())
  groupId Int
  lang    String
  name    String

  group MuscleGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, lang])
}

model MuscleToGroup {
  muscleId Int
  groupId  Int

  muscle Muscle      @relation(fields: [muscleId], references: [id], onDelete: Cascade)
  group  MuscleGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([muscleId, groupId])
}

model ExerciseMuscle {
  exerciseId Int
  muscleId   Int

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscle   Muscle   @relation(fields: [muscleId], references: [id], onDelete: Cascade)

  @@id([exerciseId, muscleId])
}

model Routine {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  title       String
  description String?

  version Int @default(1)

  categories RoutineToCategory[]
  exercises  RoutineExercise[]
  workouts   Workout[]

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoutineCategory {
  id    Int     @id @default(autoincrement())
  icon  String?
  color String?

  translations RoutineCategoryTranslation[]
  routines     RoutineToCategory[]
}

model RoutineCategoryTranslation {
  id          Int     @id @default(autoincrement())
  categoryId  Int
  lang        String
  name        String
  description String?

  category RoutineCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, lang])
}

model RoutineToCategory {
  routineId  Int
  categoryId Int

  routine  Routine         @relation(fields: [routineId], references: [id], onDelete: Cascade)
  category RoutineCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([routineId, categoryId])
}

model RoutineExercise {
  id         Int @id @default(autoincrement())
  routineId  Int
  exerciseId Int

  order Int

  reps     Int?
  sets     Int?
  duration Int?
  rest     Int?

  routine  Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([routineId, order])
}

model Workout {
  id        Int    @id @default(autoincrement())
  routineId Int?
  title     String

  startTime DateTime
  endTime   DateTime
  totalTime Int

  routine Routine? @relation(fields: [routineId], references: [id], onDelete: SetNull)

  exercises WorkoutExercise[]
  muscles   WorkoutMuscle[]

  metadata Json?

  createdAt DateTime @default(now())

  @@index([endTime])
}

model WorkoutExercise {
  id         Int @id @default(autoincrement())
  workoutId  Int
  exerciseId Int

  order Int

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  sets WorkoutSet[]

  @@index([workoutId])
}

model WorkoutSet {
  id                Int @id @default(autoincrement())
  workoutExerciseId Int

  setNumber Int
  reps      Int?
  duration  Int?
  weight    Float?

  completedAt DateTime

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([workoutExerciseId])
}

model WorkoutMuscle {
  workoutId Int
  muscleId  Int

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  muscle  Muscle  @relation(fields: [muscleId], references: [id], onDelete: Cascade)

  @@id([workoutId, muscleId])
}
